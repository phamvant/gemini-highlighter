{
  "manifest_version": 3,
  "name": "Gemini Highlighter",
  "version": "1.0.0",
  "description": "Select article text, copy a Gemini prompt, open Gemini in a popup window, and restore linked highlights.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "minimum_chrome_version": "116",
  "permissions": [
    "storage",
    "contextMenus",
    "clipboardWrite",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content-match.js", "highlight-restore.js", "clipboard-format.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Gemini Highlighter",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
